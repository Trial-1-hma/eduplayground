# Server port
PORT=5000

# PostgreSQL connection string (optional — app falls back to in-memory store without it)
# DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# GitHub Models — Foundry IQ integration (free, required for AI Riddle feature)
# 1. Go to github.com → Settings → Developer settings → Personal access tokens → Tokens (classic)
# 2. Generate a new token with NO scopes selected
# 3. Paste it below
GITHUB_TOKEN=ghp_your_token_here
